AI_PROVIDER=grobotai
AI_API_BASE_URL=https://atest.grobotai.cn/
AI_API_TOKEN=Bearer your_token
# Use a text/multimodal model here for prompt extraction.
AI_API_MODEL=doubao-seed-2-0-pro-260215
GROBOTAI_PROMPT_PATH=/api/agent/doubao_generate_character_wf
GROBOTAI_ENTERPRISE_ID=136
AI_CHAT_COMPLETIONS_PATH=/api/v3/chat/completions
# Optional quality gate for prompt generation.
AI_PROMPT_SELF_CHECK=1
AI_PROMPT_SELF_CHECK_ROUNDS=3
AI_PROMPT_SELF_CHECK_MIN_SCORE=82
